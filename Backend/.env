# ============================================
# HOTEL PARADISE - CORREÇÃO DO .ENV
# ============================================

Write-Host "🔧 Configurando arquivo .env..." -ForegroundColor Cyan

# 1. Entrar na pasta backend
cd D:\Code\Projectos Code\Sistema de Reserva de Quarto\Sistema 2\hotel-paradise\backend

# 2. Verificar se .env.example existe
if (Test-Path ".env.example") {
    Write-Host "✅ .env.example encontrado" -ForegroundColor Green
    
    # 3. Copiar para .env
    Copy-Item .env.example .env -Force
    Write-Host "✅ Arquivo .env criado a partir do exemplo" -ForegroundColor Green
    
    # 4. Mostrar conteúdo do .env
    Write-Host "`n📄 Conteúdo do arquivo .env:" -ForegroundColor Yellow
    Get-Content .env
} else {
    Write-Host "❌ .env.example não encontrado!" -ForegroundColor Red
    
    # Criar .env manualmente
    $envContent = @"
NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hotel_paradise

JWT_SECRET=hotel-paradise-super-secret-key-change-this
"@
    
    $envContent | Out-File -FilePath ".env" -Encoding UTF8
    Write-Host "✅ Arquivo .env criado manualmente" -ForegroundColor Green
}

# 5. Verificar se o arquivo foi criado
Write-Host "`n📁 Verificando arquivo .env:" -ForegroundColor Cyan
if (Test-Path ".env") {
    Write-Host "✅ .env existe!" -ForegroundColor Green
} else {
    Write-Host "❌ .env ainda não existe!" -ForegroundColor Red
}

# 6. Instruções finais
Write-Host "`n🚀 Agora execute novamente:" -ForegroundColor Yellow
Write-Host "npm run dev"