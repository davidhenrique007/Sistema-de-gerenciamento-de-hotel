# =====================================================
# HOTEL PARADISE - VARIÁVEIS DE AMBIENTE
# Versão: 1.0.0
# =====================================================

# =====================================================
# SERVIDOR
# =====================================================
NODE_ENV=development
PORT=5000

# =====================================================
# BANCO DE DADOS
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hotel_paradise
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# =====================================================
# JWT (para autenticação - usado depois)
# =====================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# =====================================================
# API KEYS (para integrações futuras)
# =====================================================
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENV=sandbox

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =====================================================
# EMAIL
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@hotelparadise.com

# =====================================================
# REDIS (para cache e filas - futuro)
# =====================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =====================================================
# FRONTEND
# =====================================================
FRONTEND_URL=http://localhost:5173

# =====================================================
# PGADMIN (opcional)
# =====================================================
PGADMIN_EMAIL=admin@hotelparadise.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050
