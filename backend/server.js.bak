п»ҝ// =====================================================
// HOTEL PARADISE - SERVIDOR PRINCIPAL (ATUALIZADO)
// VersГғВЈo: 1.2.0 - COM SEED AUTOMГғВҒTICO E CONTROLE DE CONCORRГғЕ NCIA
// =====================================================

const express = require('express');
const cookieParser = require('cookie-parser');
const compression = require('compression');
const morgan = require('morgan');
const bcrypt = require('bcryptjs');
require('dotenv').config();

const db = require('./config/database');
const routes = require('./routes');
const { securityMiddleware } = require('./middlewares/security');
const { models } = require('./models');

// =====================================================
// IMPORTAГғвҖЎГғЖ’O DAS NOVAS ROTAS
// =====================================================
const reservaRoutes = require('./routes/reservaRoutes');
const stripeRoutes = require('./routes/stripeRoutes');
const pagamentoRoutes = require('./routes/pagamentoRoutes');  // <-- ADICIONADO
const webhookRoutes = require('./routes/webhookRoutes');      // <-- ADICIONADO

const app = express();
const PORT = process.env.PORT || 5000;

// =====================================================
// SEED AUTOMГғВҒTICO DE USUГғВҒRIOS
// =====================================================
const seedUsers = async () => {
  try {
    console.log('Г°ЕёЕ’Вұ Verificando usuГғВЎrios padrГғВЈo...');
    
    const users = [
      { 
        name: 'Administrador', 
        email: 'admin@hotelparadise.com', 
        pass: 'admin123', 
        role: 'admin' 
      },
      { 
        name: 'Recepcionista', 
        email: 'recepcao@hotelparadise.com', 
        pass: 'receptionist123', 
        role: 'receptionist' 
      },
      { 
        name: 'Financeiro', 
        email: 'financeiro@hotelparadise.com', 
        pass: 'financeiro123', 
        role: 'financial' 
      }
    ];
    
    for (const u of users) {
      const exists = await models.users.findByEmail(u.email);
      
      if (!exists) {
        console.log(`  Г°ЕёвҖҳВӨ Criando ${u.name}...`);
        const salt = await bcrypt.genSalt(10);
        const hash = await bcrypt.hash(u.pass, salt);
        
        await models.users.create({ 
          name: u.name, 
          email: u.email, 
          password_hash: hash, 
          role: u.role, 
          is_active: true 
        });
        
        console.log(`  ГўЕ“вҖҰ ${u.name} criado com sucesso!`);
      } else {
        console.log(`  ГўЕ“вҖҰ ${u.name} jГғВЎ existe`);
      }
    }
    
    console.log('Г°ЕёЕ’Вұ Seed de usuГғВЎrios concluГғВӯdo!\n');
  } catch (error) {
    console.error('ГўВқЕ’ Erro no seed de usuГғВЎrios:', error);
  }
};

// =====================================================
// MIDDLEWARES
// =====================================================

// SeguranГғВ§a (Helmet + CORS)
securityMiddleware(app);

// CompressГғВЈo
app.use(compression());

// Logging
if (process.env.NODE_ENV === 'development') {
  app.use(morgan('dev'));
} else {
  app.use(morgan('combined'));
}

// Parsing
app.use(express.json({ limit: '10mb' }));
app.use(cookieParser());
app.use(express.urlencoded({ extended: true, limit: '10mb' }));

// =====================================================
// ROTAS
// =====================================================

// Rotas da API existentes
app.use('/api', routes);

// Rotas de reserva com controle de concorrГғВӘncia
app.use('/api', reservaRoutes);
app.use('/api/stripe', stripeRoutes);
// Endpoint de teste Stripe
app.get('/api/test-stripe', (req, res) => {
    res.json({ 
        success: true, 
        message: 'Stripe endpoint funcionando!',
        stripeKey: process.env.STRIPE_SECRET_KEY ? 'Configurada' : 'NГЈo configurada'
    });
});

// Rotas de pagamento M-Pesa
app.use('/api/pagamentos', pagamentoRoutes);  // <-- ADICIONADO
app.use('/api/webhooks', webhookRoutes);      // <-- ADICIONADO

// Rota raiz
app.get('/', (req, res) => {
  res.json({
    success: true,
    data: {
      name: 'Hotel Paradise API',
      version: '1.2.0',
      environment: process.env.NODE_ENV,
      timestamp: new Date().toISOString(),
      endpoints: {
        auth: '/api/auth',
        users: '/api/users',
        rooms: '/api/rooms',
        reservas: '/api/reservas',
        quartos: '/api/quartos/disponiveis',
        pagamentos: '/api/pagamentos/mpesa/iniciar',
        webhook: '/api/webhooks/mpesa/confirmar',
        health: '/api/health'
      }
    }
  });
});

// =====================================================
// TRATAMENTO DE ERROS
// =====================================================

// 404
app.use((req, res) => {
  res.status(404).json({
    success: false,
    message: 'Rota nГғВЈo encontrada'
  });
});

// Erro global
app.use((err, req, res, next) => {
  console.error('ГўВқЕ’ Erro:', err);
  
  const statusCode = err.statusCode || 500;
  const message = err.message || 'Erro interno do servidor';
  
  res.status(statusCode).json({
    success: false,
    message,
    error: process.env.NODE_ENV === 'development' ? err.stack : undefined,
    timestamp: new Date().toISOString()
  });
});

// =====================================================
// INICIALIZAГғвҖЎГғЖ’O
// =====================================================
const server = app.listen(PORT, async () => {
  console.log('\n=================================');
  console.log('Г°ЕёЕЎвӮ¬ HOTEL PARADISE - BACKEND');
  console.log('=================================');
  console.log(`Г°ЕёвҖңВЎ Servidor: http://localhost:${PORT}`);
  console.log(`Г°ЕёвҖқВ§ Ambiente: ${process.env.NODE_ENV || 'development'}`);
  console.log(`Г°ЕёвҖңвҖ№ DocumentaГғВ§ГғВЈo: http://localhost:${PORT}/`);
  console.log(`ГўВқВӨГҜВёВҸ Health check: http://localhost:${PORT}/api/health`);
  console.log(`Г°ЕёВҸВЁ Quartos disponГғВӯveis: http://localhost:${PORT}/api/quartos/disponiveis`);
  console.log(`Г°ЕёвҖңВқ Reservas: http://localhost:${PORT}/api/reservas`);
  console.log(`Г°ЕёвҖҷВ° Pagamento M-Pesa: http://localhost:${PORT}/api/pagamentos/mpesa/iniciar`);
  console.log(`Г°ЕёвҖқвҖқ Webhook M-Pesa: http://localhost:${PORT}/api/webhooks/mpesa/confirmar`);
  console.log('=================================\n');

  await seedUsers();
});

// Graceful shutdown
process.on('SIGTERM', () => gracefulShutdown('SIGTERM'));
process.on('SIGINT', () => gracefulShutdown('SIGINT'));

async function gracefulShutdown(signal) {
  console.log(`\nГ°ЕёвҖәвҖҳ Recebido ${signal}, fechando conexГғВөes...`);
  
  server.close(() => {
    console.log('ГўЕ“вҖҰ Servidor HTTP encerrado');
  });
  
  try {
    await db.pool.end();
    console.log('ГўЕ“вҖҰ ConexГғВөes com banco encerradas');
    process.exit(0);
  } catch (err) {
    console.error('ГўВқЕ’ Erro ao encerrar:', err);
    process.exit(1);
  }
}

module.exports = app;

