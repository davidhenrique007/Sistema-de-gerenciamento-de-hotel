NODE_ENV=development
PORT=5000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hotel_paradise

# Configurações do Pool de Conexões
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Configurações do Redis (HABILITADO)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=true

# Controle de Concorrência
LOCK_TIMEOUT_MS=10000
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=100

# Fila de Processamento (Bull)
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=1000
QUEUE_TIMEOUT_MS=30000

# Segurança
JWT_SECRET=hotel-paradise-super-secret-key
JWT_EXPIRES_IN=7d

# Logs
LOG_LEVEL=info
DEBUG=false

# ============================================
# CONFIGURAÇÕES M-PESA (Daraja API)
# ============================================
MPESA_API_KEY=sua_api_key_aqui
MPESA_PUBLIC_KEY=sua_public_key_aqui
MPESA_SERVICE_PROVIDER_CODE=seu_codigo_aqui
MPESA_BASE_URL=https://sandbox.api.mpesa.com
MPESA_PAYMENT_TIMEOUT=120000
MPESA_WEBHOOK_URL=https://seu-dominio.com/api/webhooks/mpesa/confirmar
MPESA_VALIDATE_SIGNATURE=false

# ============================================
# CONFIGURAÇÕES STRIPE (Pagamento com Cartão)
